# PostgreSQL (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/insight_guardian?schema=public"

# Redis (sessions, rate limiting, pub/sub)
REDIS_URL="redis://localhost:6379"

# JWT — use long random strings in production
JWT_SECRET="change-me-access-token-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-token-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

PORT=3001
NODE_ENV=development

# Vite default; must match browser origin for credentialed CORS
FRONTEND_URL="http://localhost:5173"
